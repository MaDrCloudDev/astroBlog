<button
	id='themeToggle'
	type='button'
	class='inline-flex h-10 w-10 items-center justify-center rounded-lg border border-black/10 text-[#171717] hover:border-black/30 hover:bg-black hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/40 dark:border-white/15 dark:text-[#f5f5f5] dark:hover:border-white/30 dark:hover:bg-white dark:hover:text-black dark:focus-visible:ring-white/40'
	aria-label='Toggle theme'
	aria-pressed='true'>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='0 0 24 24'
		class='h-[18px] w-[18px] dark:hidden'
		aria-hidden='true'>
		<path
			fill='none'
			stroke='currentColor'
			stroke-linecap='round'
			stroke-linejoin='round'
			stroke-width='1.8'
			d='M12 3.5v2.2m0 12.6v2.2M5.64 5.64l1.56 1.56m9.6 9.6 1.56 1.56M3.5 12h2.2m12.6 0h2.2M5.64 18.36l1.56-1.56m9.6-9.6 1.56-1.56M12 16.2a4.2 4.2 0 1 0 0-8.4 4.2 4.2 0 0 0 0 8.4z'
		></path>
	</svg>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='0 0 24 24'
		class='hidden h-[18px] w-[18px] dark:block'
		aria-hidden='true'>
		<path
			fill='none'
			stroke='currentColor'
			stroke-linecap='round'
			stroke-linejoin='round'
			stroke-width='1.8'
			d='M21 12.7A8.8 8.8 0 1 1 11.3 3a7 7 0 0 0 9.7 9.7z'
		></path>
	</svg>
</button>

<script is:inline>
	const storageKey = "theme";
	const rootElement = document.documentElement;
	const themeToggleButton = document.getElementById("themeToggle");
	const storedTheme = localStorage.getItem(storageKey);
	const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)")
		.matches
		? "dark"
		: "light";
	const initialTheme =
		storedTheme === "dark" || storedTheme === "light"
			? storedTheme
			: preferredTheme;

	const applyTheme = (theme) => {
		rootElement.classList.toggle("dark", theme === "dark");
		rootElement.style.colorScheme = theme;

		if (themeToggleButton) {
			themeToggleButton.setAttribute(
				"aria-pressed",
				String(theme === "dark")
			);
		}
	};

	applyTheme(initialTheme);
	localStorage.setItem(storageKey, initialTheme);

	themeToggleButton?.addEventListener("click", () => {
		const nextTheme = rootElement.classList.contains("dark")
			? "light"
			: "dark";

		applyTheme(nextTheme);
		localStorage.setItem(storageKey, nextTheme);
	});
</script>
