---
import Social from "./Social.astro";
import { SITE_URL, SOCIAL_LINKS } from "../lib/site";

const currentYear = new Date().getFullYear();
const rssUrl = `${SITE_URL}/rss.xml`;
---

<footer class='mx-auto mt-4 w-full max-w-5xl border-t border-black/10 px-4 pb-10 pt-6 dark:border-white/10 sm:px-6'>
	<div class='flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between'>
		<div class='flex flex-wrap gap-2'>
			{
				SOCIAL_LINKS.map((social) => (
					<Social
						href={social.href}
						label={social.label}
					/>
				))
			}
		</div>
		<div class='flex items-center gap-4 text-xs uppercase tracking-[0.12em] text-[#71717a] dark:text-[#a1a1aa]'>
			<a
				class='font-semibold text-[#3f3f46] hover:text-black dark:text-[#d4d4d8] dark:hover:text-white'
				href={rssUrl}
				aria-label='Open RSS feed'
				>RSS</a
			>
			<span>{currentYear}</span>
		</div>
	</div>
</footer>
