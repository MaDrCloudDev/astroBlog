---
import { Image } from "astro:assets";
import { formatDate } from "../lib/date";
import { getPostUrl, normalizeTag, type BlogPost } from "../lib/content";
import { getTagNeonBorderClasses } from "../lib/tagBadgeStyles";

interface Props {
	post: BlogPost;
}

const { post } = Astro.props as Props;
const postUrl = getPostUrl(post);
const publishedOn = formatDate(post.data.pubDate);
const previewTags = [...new Set(post.data.tags.map((tag) => normalizeTag(tag)))].slice(0, 3);
---

<li class='list-none w-full'>
	<article class='group h-full overflow-hidden rounded-2xl border border-black/10 bg-white/75 shadow-[0_14px_48px_-24px_rgba(0,0,0,0.55)] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-black/20 hover:shadow-[0_20px_48px_-24px_rgba(0,0,0,0.7)] sm:aspect-[1.1/1] dark:border-white/10 dark:bg-[#0f0f10]/90 dark:shadow-[0_14px_42px_-20px_rgba(0,0,0,0.9)] dark:hover:border-white/20'>
		<a
			class='flex h-full flex-col focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/40 dark:focus-visible:ring-white/40'
			href={postUrl}
			aria-label={`Read ${post.data.title}`}>
			<div class='relative h-44 overflow-hidden sm:h-[40%]'>
				<Image
					class='h-full w-full object-cover grayscale-[40%] contrast-110 transition-all duration-500 group-hover:scale-[1.04] group-hover:grayscale-0'
					width={1200}
					height={900}
					format='webp'
					src={post.data.image.url}
					alt={post.data.image.alt}
				/>
				<div class='pointer-events-none absolute inset-0 bg-gradient-to-t from-black/55 via-black/15 to-transparent'></div>
			</div>
			<div class='flex min-h-0 flex-1 flex-col gap-3 p-4 sm:p-5'>
				<div class='flex flex-wrap items-center gap-2 text-[11px] font-medium uppercase tracking-[0.14em] text-[#71717a] dark:text-[#a1a1aa]'>
					<time datetime={post.data.pubDate.toISOString()}>{publishedOn}</time>
					<span class='h-1 w-1 rounded-full bg-current/60'></span>
					<span>{post.data.author}</span>
				</div>
				<h2 class='text-xl font-semibold leading-tight text-[#111111] transition-colors group-hover:text-black dark:text-white dark:group-hover:text-white sm:text-2xl'>
					{post.data.title}
				</h2>
				<p class='overflow-hidden text-sm leading-relaxed text-[#3f3f46] [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:3] dark:text-[#a1a1aa] sm:text-[15px]'>
					{post.data.description}
				</p>
				{
					previewTags.length > 0 && (
						<ul
							class="flex flex-wrap gap-2 pt-0.5"
							aria-label="Post tags"
						>
							{previewTags.map((tag) => (
								<li class="list-none">
									<span
										class:list={[
											"inline-flex items-center rounded-full border bg-white/60 px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.08em] text-[#3f3f46] backdrop-blur-sm dark:bg-black/30 dark:text-[#d4d4d8]",
											getTagNeonBorderClasses(tag),
										]}
									>
										{tag}
									</span>
								</li>
							))}
						</ul>
					)
				}
				<p class='mt-auto pt-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-[#3f3f46] transition-colors group-hover:text-black dark:text-[#d4d4d8] dark:group-hover:text-white'>
					Read post
				</p>
			</div>
		</a>
	</article>
</li>
