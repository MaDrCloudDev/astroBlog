---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import {
	getAllPosts,
	getPostsForTag,
	getSortedTags,
	type BlogPost,
} from "../../lib/content";

export async function getStaticPaths() {
	const allPosts = await getAllPosts();
	const allTags = getSortedTags(allPosts);

	return allTags.map((tag) => {
		const posts = getPostsForTag(allPosts, tag);
		return {
			params: { tag },
			props: { posts },
		};
	});
}

const { tag } = Astro.params;
const selectedTag = tag ?? "tag";
const { posts } = Astro.props as { posts: BlogPost[] };
---

<BaseLayout title={`${selectedTag} | MaDr`}>
	<section class='space-y-7'>
		<header class='space-y-3'>
			<a
				class='inline-flex text-xs uppercase tracking-[0.2em] text-[#71717a] hover:text-black dark:text-[#a1a1aa] dark:hover:text-white'
				href='/tags/'
				>All tags</a
			>
			<h1 class='text-3xl font-semibold text-[#111111] dark:text-white sm:text-4xl'>
				#{selectedTag}
			</h1>
			<p class='text-sm text-[#52525b] dark:text-[#a1a1aa]'>
				{posts.length} {posts.length === 1 ? "post" : "posts"} tagged with
				{` ${selectedTag}`}.
			</p>
		</header>
		<ul class='grid grid-cols-1 gap-6 sm:gap-8'>
		{
			posts.map((post) => (
				<BlogCard post={post} />
			))
		}
		</ul>
	</section>
</BaseLayout>
