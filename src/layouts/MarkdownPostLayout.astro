---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import { formatDate } from "../lib/date";
import type { BlogPost } from "../lib/content";

interface Props {
	post: BlogPost;
}

const { post } = Astro.props as Props;
const publishedOn = formatDate(post.data.pubDate);
---

<BaseLayout
	title={`${post.data.title} | MaDr`}
	description={post.data.description}>
	<article class='mx-auto w-full max-w-4xl'>
		<header class='mb-8 space-y-4 border-b border-black/10 pb-8 dark:border-white/10'>
			<p class='text-xs uppercase tracking-[0.2em] text-[#71717a] dark:text-[#a1a1aa]'>
				<time datetime={post.data.pubDate.toISOString()}>{publishedOn}</time>
			</p>
			<h1 class='text-3xl font-semibold leading-tight text-[#111111] dark:text-white sm:text-4xl'>
				{post.data.title}
			</h1>
			<p class='max-w-3xl text-base leading-relaxed text-[#3f3f46] dark:text-[#a1a1aa]'>
				{post.data.description}
			</p>
			<p class='text-sm text-[#52525b] dark:text-[#d4d4d8]'>
				Written by <span class='font-semibold'>{post.data.author}</span>
			</p>
			<div class='overflow-hidden rounded-2xl border border-black/10 dark:border-white/10'>
				<Image
					src={post.data.image.url}
					width={1200}
					height={675}
					format='webp'
					alt={post.data.image.alt}
					class='h-full w-full object-cover'
				/>
			</div>
		</header>
		<div class='prose prose-zinc max-w-none prose-headings:font-semibold prose-a:text-inherit prose-a:decoration-[#71717a] prose-a:decoration-1 prose-a:underline-offset-4 hover:prose-a:text-black hover:prose-a:decoration-black dark:prose-invert dark:hover:prose-a:text-white dark:hover:prose-a:decoration-white'>
			<slot />
		</div>
	</article>
</BaseLayout>
